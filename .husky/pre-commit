# In a linked worktree (.git is a file), delegate to the agent hook.
# The agent hook skips lint-staged: PostToolUse formatters handle formatting on every edit.
if [ -f ".git" ]; then
  exec ./claude/hooks/pre-commit
fi

./scripts/check-conflict-markers.sh --staged
# lint-staged runs `eslint --fix --max-warnings 0` on staged files, which
# enforces the file-length hard cap via the `max-lines` rule — no separate
# length check needed.
pnpm exec lint-staged
pnpm run env:validate
