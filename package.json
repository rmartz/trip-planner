{
  "name": "firebase-nextjs-template",
  "version": "0.1.0",
  "description": "Template repository for Next.js projects built on Firebase",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "tsc": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "prepare": "husky",
    "env:pull": "generate-local-env",
    "env:validate": "node scripts/validate-config.mjs",
    "migrate:member-uids": "node scripts/migrate-member-uids.mjs",
    "secrets-check": "pnpm run env:validate && secrets-check --config .gitleaks.toml"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,jsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{js,mjs,cjs,ts,tsx,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@sentry/nextjs": "^10.56.0",
    "@tanstack/react-query": "^5.101.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-redux": "^9.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vercel-deploy-scripts": "github:rmartz/vercel-deploy-scripts#v3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/addon-vitest": "^10.4.5",
    "@storybook/nextjs-vite": "^10.4.5",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.5",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.11.0",
    "storybook": "^10.4.5",
    "tailwindcss": "^4",
    "typescript": "^6",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
