{
  "name": "firebase-nextjs-template",
  "version": "0.1.0",
  "description": "Template repository for Next.js projects built on Firebase",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "tsc": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "prepare": "husky",
    "env:pull": "generate-local-env",
    "env:validate": "node scripts/validate-config.mjs",
    "migrate:member-uids": "node scripts/migrate-member-uids.mjs",
    "secrets-check": "pnpm run env:validate && secrets-check --config .gitleaks.toml"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,jsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{js,mjs,cjs,ts,tsx,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@protobufjs/utf8@<=1.1.0": ">=1.1.1",
      "@tootallnate/once@<3.0.1": ">=3.0.1",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "fast-xml-builder@<=1.1.6": ">=1.1.7",
      "fast-xml-builder@=1.1.5": ">=1.1.6",
      "hono@<4.12.18": ">=4.12.18",
      "ip-address@<=10.1.0": ">=10.1.1",
      "next@>=16.0.0 <16.2.5": ">=16.2.5",
      "next@>=16.0.0 <16.2.6": ">=16.2.6",
      "postcss@<8.5.10": ">=8.5.10",
      "protobufjs@<=7.5.5": ">=7.5.6",
      "uuid@>=11.0.0 <11.1.1": ">=11.1.1",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-query": "^5.99.2",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-redux": "^9.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vercel-deploy-scripts": "github:rmartz/vercel-deploy-scripts#v3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.3.6",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.6.0",
    "storybook": "^10.3.6",
    "tailwindcss": "^4",
    "typescript": "^6",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
