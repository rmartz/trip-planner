#!/bin/sh
# Agent pre-commit hook — runs in linked worktrees (where .git is a file).
# Skips lint-staged: the PostToolUse formatter hook handles formatting on every edit.
set -e
./scripts/check-conflict-markers.sh --staged
pnpm run env:validate
# The file-length hard cap is now the eslint `max-lines` rule, enforced by
# `pnpm lint` in pre-push-verify (and CI). This hook does not run lint-staged,
# so the cap is checked before push rather than at each agent commit.
